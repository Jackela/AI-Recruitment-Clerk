#!/usr/bin/env sh
set -e

# Skip local CI for delete-only pushes.
delete_only=1
while read -r local_ref local_ref local_sha remote_sha; do
  if [ "$local_ref" != "0000000000000000000000000000000000000000" ]; then
    delete_only=0
    break
  fi
done

if [ "$delete_only" -eq 1 ]; then
  echo "⏭️  Skipping ci:local for delete-only push"
  exit 0
fi

echo "🚀 Running ENHANCED pre-push CI checks..."
echo "⏱️  This will test ALL projects. May take 10-15 minutes."
echo ""

# Start time
START_TIME=$(date +%s)

# 1. Lint all (includes any-type check via @typescript-eslint/no-explicit-any)
echo "📋 Step 1/8: Linting ALL projects (including any-type check)..."
npm run lint
echo "✅ Lint passed (no any types found)"
echo ""

# 2. Format check
echo "🎨 Step 2/8: Checking code formatting..."
npx prettier --check "{apps,libs}/**/*.{ts,html,scss,js,json,md}" || {
  echo "❌ Code formatting issues found. Run 'npm run format' to fix."
  exit 1
}
echo "✅ Format check passed"
echo ""

# 3. Typecheck all
echo "🔍 Step 3/8: Type-checking ALL projects..."
npm run typecheck
echo "✅ Typecheck passed"
echo ""

# 4. Security audit
echo "🔒 Step 4/8: Running security audit..."
npm audit --audit-level=high || {
  echo "⚠️  Security vulnerabilities found. Review with: npm audit"
  echo "   To fix automatically: npm audit fix"
  echo "   Continuing despite warnings..."
}
echo ""

# 5. All unit tests with coverage
echo "🧪 Step 5/8: Running ALL unit tests with coverage..."
npm run test:coverage

# Check coverage thresholds
COVERAGE_FILE="coverage/lcov-report/index.html"
if [ -f "$COVERAGE_FILE" ]; then
  # Extract coverage percentage from HTML
  LINE_COVERAGE=$(grep -oP 'Lines</th><td[^>]*>\K[0-9]+' "$COVERAGE_FILE" || echo "0")
  BRANCH_COVERAGE=$(grep -oP 'Branches</th><td[^>]*>\K[0-9]+' "$COVERAGE_FILE" || echo "0")
  
  echo "📊 Coverage Report:"
  echo "   Lines: ${LINE_COVERAGE}%"
  echo "   Branches: ${BRANCH_COVERAGE}%"
  
  # Check if coverage meets thresholds
  if [ "$LINE_COVERAGE" -lt 80 ]; then
    echo "❌ Line coverage is below 80% threshold"
    exit 1
  fi
  if [ "$BRANCH_COVERAGE" -lt 70 ]; then
    echo "❌ Branch coverage is below 70% threshold"
    exit 1
  fi
  echo "✅ Coverage thresholds met"
fi
echo ""

# 6. Build all (including frontend for E2E)
echo "🔨 Step 6/8: Building ALL projects..."
npm run build

# Build frontend specifically for E2E
echo "📦 Building frontend for E2E..."
npx nx run ai-recruitment-frontend:build:production
echo "✅ Build passed"
echo ""

# 7. Start static server for E2E in background
echo "🌐 Starting static server for E2E..."
npx serve dist/apps/ai-recruitment-frontend/browser -l 4200 -s > /tmp/e2e-server.log 2>&1 &
SERVER_PID=$!
echo "Server started with PID: $SERVER_PID"

# Wait for server to be ready
echo "Waiting for server to be ready..."
for i in $(seq 1 30); do
  if curl -s http://localhost:4200 > /dev/null 2>&1; then
    echo "✅ Server is ready!"
    break
  fi
  if [ $i -eq 30 ]; then
    echo "❌ Server failed to start"
    cat /tmp/e2e-server.log
    kill $SERVER_PID 2>/dev/null
    exit 1
  fi
  sleep 1
done

# 8. E2E tests - MUST PASS
# Skip slow PDF tests that require backend API (@pdf-variety, @real-data tags)
echo "🎭 Step 7/8: Running E2E tests (skipping slow PDF integration tests)..."
export CI=true
export E2E_SKIP_WEBSERVER=true
export PLAYWRIGHT_BASE_URL=http://localhost:4200
cd apps/ai-recruitment-frontend-e2e && npx playwright test --grep-invert '@pdf-variety|@real-data'
E2E_EXIT_CODE=$?

# Stop the server
echo "Stopping server..."
kill $SERVER_PID 2>/dev/null || true
wait $SERVER_PID 2>/dev/null || true

if [ $E2E_EXIT_CODE -ne 0 ]; then
  echo "❌ E2E tests failed"
  exit 1
fi
echo "✅ E2E tests passed"
echo ""

# 9. Nx affected test (quick sanity check)
echo "🔄 Step 8/8: Running affected tests..."
cd ../..
npx nx affected:test --base=main --head=HEAD --parallel=4 || {
  echo "⚠️  Some affected tests failed, but continuing..."
}
echo ""

# Calculate elapsed time
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))
MINUTES=$((ELAPSED / 60))
SECONDS=$((ELAPSED % 60))

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "✅ ALL ENHANCED pre-push checks passed!"
echo "⏱️  Total time: ${MINUTES}m ${SECONDS}s"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
